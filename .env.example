# =============================================================================
# StemScribe Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

# ---- App ----
FLASK_ENV=development
APP_URL=http://localhost:5555
API_URL=http://localhost:5555
PORT=5555

# ---- Database (Supabase Postgres) ----
# Get from Supabase Dashboard → Settings → Database → Connection String (URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ---- JWT Authentication ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_64_char_random_string
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ---- Stripe Billing ----
# Get from Stripe Dashboard → Developers → API Keys
# Use sk_test_* keys for development!
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_PRICE_PREMIUM_MONTHLY=price_XXXXXXXXX
STRIPE_PRICE_PREMIUM_ANNUAL=price_XXXXXXXXX
STRIPE_PRICE_PRO_MONTHLY=price_XXXXXXXXX
STRIPE_PRICE_PRO_ANNUAL=price_XXXXXXXXX

# ---- Cloudflare R2 Storage ----
# Get from Cloudflare Dashboard → R2 → Manage R2 API Tokens
CF_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=stemscribe-uploads

# ---- Replicate (GPU processing) ----
# Get from replicate.com → Account → API Tokens
REPLICATE_API_TOKEN=r8_YOUR_REPLICATE_TOKEN

# ---- Email (Resend) ----
# Get from resend.com → API Keys
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
# Toggle for "your song is ready" emails after job completion. Set to "true"
# at launch; leave unset / "false" to silently skip (e.g. if the provider is
# misfiring). See backend/notifications.py.
ENABLE_JOB_EMAILS=false
# Optional override for the From: header on job-complete emails.
# Default: "StemScriber <noreply@stemscribe.app>"
# EMAIL_FROM_JOB=StemScriber <noreply@stemscribe.app>

# ---- Optional: Redis (for rate limiting / job queue) ----
# If using Railway Redis plugin, this is set automatically
# REDIS_URL=redis://localhost:6379

# ---- Feature Flags ----
# CRNN-based MIDI transcription (guitar, bass, drums, piano) + Trimplexx guitar
# tablature. These are CPU-bound and add ~2-3 min wall time + significant
# memory pressure per upload. Tab view is cut for the 2026-05-12 launch, so
# default OFF. Set to "true" / "1" / "yes" to re-enable once tab view ships.
# Accepted off values: unset, "false", "0", "no" (anything not in the true set).
ENABLE_CRNN_TRANSCRIPTION=false

# ---- MIDI-Intermediate Chord Detector (Phase 2 rebuild, 2026-04-23) ----
# New note-based detector: Basic Pitch MIDI per stem → per-bar note
# windowing → template match against {maj, min, 5, 6, m6, 7, m7, maj7,
# m7b5, dim7, sus2, sus4, aug, add9, 9, m9, maj9}. Fixes the current
# detector's inability to output 7ths (see docs/midi-chord-detector-
# spec-2026-04-23.md and docs/midi-prototype-results-2026-04-23.md).
#
# Default OFF through 2026-05-12 launch. Flip to "true" only after the
# Phase 4 regression passes (new detector wins on ≥15 of 20 Kozelski
# songs vs the existing stem-aware path). Gives us a one-line rollback
# if launch-day traffic surfaces edge cases the regression didn't catch.
ENABLE_MIDI_DETECTOR=false

# Pitch-class energy floor for the MIDI detector. A template interval's
# pitch class is considered "strong" (full scoring credit) when its
# amplitude×duration weight is at least this fraction of the loudest pc
# in the bar. Below the floor, a template interval still earns partial
# credit but a NON-template pc is ignored (not counted as a spurious
# extra). 0.05 = 5% of peak; conservative default. Raise (e.g. 0.08)
# to be stricter about promoting triads to 7ths/9ths; lower (e.g. 0.03)
# to catch quieter extensions. Tune per catalog — acoustic/folk songs
# may benefit from a lower floor than pop/rock.
MIDI_DETECTOR_ENERGY_FLOOR=0.05

# ---- Upload / Output Retention ----
# Automatic cleanup of stale user uploads and generated outputs. Per legal
# guidance (Alexandra Mayo, April 10 call) we do not retain user-uploaded
# audio or derived charts indefinitely. See backend/processing/retention.py.
#
# Policy (applies only to jobs with status in {completed, failed}; demo
# songs and jobs with metadata.retain=True are exempt):
#   UPLOAD_RETENTION_HOURS   uploads/<jobId>/  deleted this many hours
#                            after completion (default 48).
#   OUTPUT_RETENTION_DAYS    outputs/<jobId>/  deleted this many days
#                            after completion (default 7).
#   RETENTION_INTERVAL_HOURS how often the sweeper runs (default 1h).
#   RETENTION_ENABLED        master switch (default true).
#   RETENTION_DRY_RUN        true = log deletions only, do not delete.
#                            Default TRUE — flip to false when ready.
UPLOAD_RETENTION_HOURS=48
OUTPUT_RETENTION_DAYS=7
RETENTION_INTERVAL_HOURS=1
RETENTION_ENABLED=true
RETENTION_DRY_RUN=true
